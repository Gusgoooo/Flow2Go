# Flow2Go Routify（与 codify 类似：服务端持 AK，前端只发 X-API-Token）
# 复制为 .env.local 后填写；勿将真实密钥提交到仓库

# ── Express 代理（npm run dev:server / npm start）──
# 默认 X-API-Token: flow2go_routify → 使用下列变量
ROUTIFY_API_KEY=
# 可选；默认 https://routify.alibaba-inc.com/protocol/openai/v1
# ROUTIFY_BASE_URL=

# 可选：多 Token 映射（JSON）。值为「环境变量名」，不是密钥本身。
# 例：{"staging":{"apiKeyEnv":"ROUTIFY_API_KEY_STAGING","baseUrlEnv":"ROUTIFY_BASE_URL_STAGING"}}
# ROUTIFY_TOKEN_MAP_JSON=

# ── 前端直连回退（仅在不走 Express 代理且构建时注入时使用）──
VITE_ROUTIFY_API_KEY=

# 请求服务端代理时带的 Token（与 server 侧解析一致，默认 flow2go_routify）
# VITE_ROUTIFY_X_API_TOKEN=
